---
import Icon from "./Icon.astro";
import { SITE, categories } from "../lib/blog-data.js";
import { SOCIAL_LINKS } from "../config/theme.config.ts";

const { flush = false } = Astro.props;
---

<footer class:list={[flush ? "mt-0" : "mt-24", "border-t border-border/60"]}>
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex flex-col gap-6 border-b border-border/60 pb-8 md:flex-row md:items-end md:justify-between">
      <div class="max-w-md">
        <div class="font-serif text-2xl font-medium tracking-[-0.01em]">{SITE.name}</div>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          {SITE.description}
        </p>
      </div>
      <div class="flex items-center gap-3 text-muted-foreground">
        {
          SOCIAL_LINKS.map((link) => (
            <a href={link.href} aria-label={link.label} class="hover:text-foreground">
              <Icon name={link.icon} class="h-4 w-4" />
            </a>
          ))
        }
      </div>
    </div>
    <div class="grid gap-10 pt-8 sm:grid-cols-2 md:grid-cols-3">
      <div>
        <div class="meta-label text-muted-foreground">Sections</div>
        <ul class="mt-3 space-y-2 text-sm">
          {
            categories.slice(0, 5).map((category) => (
              <li>
                <a href={`/categories/${category.slug}`} class="text-foreground/80 hover:text-foreground">
                  {category.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <div class="meta-label text-muted-foreground">The site</div>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/about" class="text-foreground/80 hover:text-foreground">About</a></li>
          <li><a href="/contact" class="text-foreground/80 hover:text-foreground">Contact</a></li>
          <li><a href="/blog" class="text-foreground/80 hover:text-foreground">Archive</a></li>
          <li><a href="/rss.xml" class="text-foreground/80 hover:text-foreground">RSS feed</a></li>
        </ul>
      </div>
      <div>
        <div class="meta-label text-muted-foreground">Colophon</div>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Set in Fraunces &amp; Inter, with JetBrains Mono for code. Built on the open web.
        </p>
      </div>
    </div>
  </div>
  <div class="border-t border-border/60">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-2 px-5 py-5 text-xs text-muted-foreground sm:flex-row sm:items-center">
      <div>&copy; {new Date().getFullYear()} {SITE.name}. Quietly made on the open web.</div>
      <div class="meta-label">Set in Fraunces &amp; Inter</div>
    </div>
  </div>
</footer>
