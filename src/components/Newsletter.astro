---
import { FORMS } from "../config/theme.config.ts";

const { compact = false } = Astro.props;
const hasNewsletterEndpoint = Boolean(FORMS.newsletter.action);
const newsletterAction = hasNewsletterEndpoint ? FORMS.newsletter.action : "/contact";
const newsletterMethod = hasNewsletterEndpoint ? FORMS.newsletter.method : "get";
const newsletterEnctype = hasNewsletterEndpoint ? FORMS.newsletter.enctype : undefined;
---

{
  compact ? (
    <div>
      <div class="meta-label text-primary">Newsletter</div>
      <p class="mt-2 text-sm text-muted-foreground">A short letter, once a fortnight. No noise.</p>
      <form
        action={newsletterAction}
        method={newsletterMethod}
        enctype={newsletterEnctype}
        class="mt-3 flex gap-2"
      >
        <label for="newsletter-email-compact" class="sr-only">Email address</label>
        <input
          id="newsletter-email-compact"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="min-w-0 flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm outline-none focus:border-primary"
        />
        <button type="submit" class="rounded-md bg-foreground px-3 py-2 text-sm font-medium text-background transition-opacity hover:opacity-90">
          Join
        </button>
      </form>
    </div>
  ) : (
    <section data-newsletter-cta class="mx-auto max-w-4xl px-5 py-16">
      <div class="rounded-md border border-border px-6 py-10 sm:px-10 sm:py-12">
        <div class="grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            <p class="meta-label text-primary">Newsletter</p>
            <h2 class="mt-3 font-serif text-2xl font-medium tracking-[-0.01em] sm:text-3xl">A quieter inbox.</h2>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-muted-foreground">
              One thoughtful letter every other Sunday &mdash; new essays, things worth reading, and the occasional photograph.
            </p>
          </div>
          <div>
            <form
              action={newsletterAction}
              method={newsletterMethod}
              enctype={newsletterEnctype}
              class="flex flex-col gap-2 sm:flex-row"
            >
              <label for="newsletter-email" class="sr-only">Email address</label>
              <input
                id="newsletter-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="min-w-0 flex-1 rounded-md border border-input bg-background px-4 py-3 text-sm outline-none focus:border-primary"
              />
              <button type="submit" class="rounded-md bg-foreground px-5 py-3 text-sm font-medium text-background transition-opacity hover:opacity-90">
                Subscribe
              </button>
            </form>
            <p class="mt-3 text-xs text-muted-foreground">Free. Unsubscribe in one click.</p>
          </div>
        </div>
      </div>
    </section>
  )
}
